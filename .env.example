# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OLED display ──────────────────────────────────────────────────────────────
# I2C bus (1 on Pi 5 = GPIO 2/3 = physical pins 3/5)
OLED_I2C_PORT=1
# SH1106 default address; use 0x3D if SA0 pin is pulled high
OLED_I2C_ADDRESS=0x3C

# ── Hailo AI HAT+ ─────────────────────────────────────────────────────────────
# Path to a compiled .hef model file (Hailo Executable Format)
# Download pre-built models from: https://github.com/hailo-ai/hailo_model_zoo
HAILO_HEF_PATH=models/yolov8s.hef

# ── IMX500 AI Camera ──────────────────────────────────────────────────────────
# Path to an .rpk network package for on-sensor inference (optional)
# Download from: https://github.com/raspberrypi/imx500-models
IMX500_MODEL_PATH=models/imx500_mobilenet_ssd.rpk

# ── Audio ─────────────────────────────────────────────────────────────────────
# sounddevice device index or name; leave blank for system default
# Run `python -c "import sounddevice; print(sounddevice.query_devices())"` to list
AUDIO_DEVICE=
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
